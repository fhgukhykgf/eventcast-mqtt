# ============ 数据库配置 ============
# 本地MongoDB
MONGODB_URI=mongodb://192.168.1.64:27017/eventcast

# 云MongoDB（如MongoDB Atlas）
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eventcast

# ============ MQTT配置 ============
# EMQ X服务器地址
MQTT_BROKER=192.168.1.64
MQTT_PORT=1883
# 如需TLS加密，使用8883端口
# MQTT_PORT=8883

# EMQ X管理账号
MQTT_USERNAME=admin
MQTT_PASSWORD=public

# ============ 后端服务配置 ============
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 安全配置
# ⚠️ 必须修改 SECRET_KEY 为强随机字符串！可用: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false  # 生产环境必须设为false

# CORS配置（生产环境必须设置具体域名，不要使用 *）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============ 文件路径配置 ============
# 日志目录
LOG_DIR=./logs
# 静态文件目录
STATIC_DIR=./static