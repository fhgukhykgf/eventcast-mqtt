/* pages/events/events.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

.filter-bar {
  display: flex;
  background: white;
  padding: 20rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-item {
  margin-right: 40rpx;
  padding: 8rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.filter-item.active {
  color: #1890ff;
  font-weight: 500;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

.event-list {
  padding: 30rpx;
}

.event-card {
  background: white;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
}

.event-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.event-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #1890ff, #52c41a);
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
}

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.event-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.event-status {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.status-active {
  background: #f6ffed;
  color: #52c41a;
}

.status-upcoming {
  background: #e6f7ff;
  color: #1890ff;
}

.status-ended {
  background: #fff7e6;
  color: #fa8c16;
}

.status-cancelled {
  background: #fff1f0;
  color: #ff4d4f;
}

.event-card.ended {
  opacity: 0.75;
}

.event-card.ended .event-title {
  color: #999;
}

.event-card.ended::before {
  background: linear-gradient(90deg, #faad14, #fa8c16);
}

.event-card.cancelled {
  opacity: 0.6;
  background: #fff7f7;
}

.event-card.cancelled .event-title {
  color: #999;
}

.event-card.cancelled::before {
  background: linear-gradient(90deg, #ff4d4f, #ff7875);
}

.event-card.cancelled-title,
.cancelled-title {
  color: #999;
  text-decoration: line-through;
}

.status-cancelled + .cancelled-title {
  color: #999;
}

.event-info {
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.event-time,
.event-location {
  display: block;
  margin-bottom: 8rpx;
}

.event-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
  font-size: 24rpx;
  color: #999;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.empty-state {
  padding: 100rpx 30rpx;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.4;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
  display: block;
}

.empty-state .btn {
  width: 300rpx;
  height: 80rpx;
  border-radius: 40rpx;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.load-more .loading {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 0;
  margin-right: 16rpx;
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
}