.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 30rpx;
}

.user-card {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  padding: 60rpx 30rpx;
  text-align: center;
  color: white;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.3);
  margin-bottom: 20rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.user-role {
  display: inline-block;
  margin-top: 10rpx;
  padding: 4rpx 16rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
}

.stats-card {
  background: white;
  margin: -40rpx 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1890ff;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.section {
  background: white;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 30rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #1890ff;
}

.activity-list {
  padding: 0 30rpx;
}

.activity-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-info {
  flex: 1;
}

.activity-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.activity-time {
  font-size: 24rpx;
  color: #999;
}

.activity-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.activity-status.signed {
  background: #e6f7ff;
  color: #1890ff;
}

.activity-status.applied {
  background: #fff7e6;
  color: #fa8c16;
}

.empty-state {
  text-align: center;
  padding: 60rpx 30rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

.menu-list {
  background: white;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 60rpx;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 40rpx;
  color: #999;
}

.logout-btn {
  margin: 30rpx;
  background: #ff4d4f;
  color: white;
  border: none;
}

.logout-btn::after {
  border: none;
}