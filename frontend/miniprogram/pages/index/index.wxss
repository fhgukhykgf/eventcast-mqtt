.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding-bottom: 20rpx;
}

/* 用户信息 */
.user-section {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  padding: 40rpx 30rpx 60rpx;
  color: white;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.user-role {
  font-size: 26rpx;
  opacity: 0.9;
}

.notification-btn {
  margin-left: auto;
  position: relative;
  padding: 16rpx;
}

.notification-icon {
  font-size: 44rpx;
}

.notification-badge {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background: #ff4d4f;
  color: white;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 16rpx;
  text-align: center;
}

.stats {
  display: flex;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 24rpx;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  background: white;
  margin: -30rpx 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 36rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.12);
}

.action-item {
  flex: 1;
  text-align: center;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  font-size: 60rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.15);
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
}

.action-icon::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent, rgba(255,255,255,0.3), transparent);
  transform: rotate(45deg);
  animation: shine 3s infinite;
}

@keyframes shine {
  0% { transform: translateX(-100%) rotate(45deg); }
  100% { transform: translateX(100%) rotate(45deg); }
}

.action-icon:hover {
  transform: scale(1.1) rotate(5deg);
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.2);
}

.action-icon.scan {
  background: linear-gradient(135deg, #e6f7ff, #b3d8ff);
  color: #1890ff;
}

.action-icon.events {
  background: linear-gradient(135deg, #f6ffed, #d9f7be);
  color: #52c41a;
}

.action-icon:hover {
  transform: scale(1.05);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.15);
}

/* 内容区域 */
.section {
  background: white;
  margin: 24rpx 30rpx;
  border-radius: 20rpx;
  padding: 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 活动列表 */
.event-item {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  transition: all 0.3s;
  position: relative;
}

.event-item:hover {
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  transform: translateY(-2rpx);
}

.event-item:last-child {
  margin-bottom: 0;
}

.event-item.ongoing {
  border-left: 6rpx solid #52c41a;
  background: linear-gradient(90deg, #f6ffed, white);
}

.event-item.upcoming {
  border-left: 6rpx solid #1890ff;
}

.event-main {
  flex: 1;
}

.event-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.event-badge.ongoing {
  background: #52c41a;
  color: white;
}

.event-badge.upcoming {
  background: #1890ff;
  color: white;
}

.event-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.event-time {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.event-location {
  font-size: 24rpx;
  color: #666;
  display: block;
  line-height: 1.3;
}

.event-status {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  margin-left: 20rpx;
}

.event-status.signed {
  background: #f6ffed;
  color: #52c41a;
}

.event-status.active {
  background: #e6f7ff;
  color: #1890ff;
}

.event-status.upcoming {
  background: #fff2e8;
  color: #fa8c16;
}

.event-status.missed {
  background: #fff1f0;
  color: #ff4d4f;
}

.event-status.cancelled {
  background: #fff1f0;
  color: #ff4d4f;
  text-decoration: line-through;
}

.event-item.cancelled {
  opacity: 0.7;
  background: #fffbfb;
}

.cancelled-text {
  text-decoration: line-through;
  color: #999;
}

.event-status.pending {
  background: #fff2e8;
  color: #faad14;
}

/* 加载中 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid #1890ff;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 30rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #bbb;
}