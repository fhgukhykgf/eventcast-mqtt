<!-- 签到页 -->
<view class="page">
  <!-- 成功弹窗 -->
  <view class="success-modal" wx:if="{{showSuccess}}">
    <view class="success-content">
      <text class="success-icon">✅</text>
      <text class="success-title">签到成功！</text>
      <text class="success-time">签到时间: {{signResult.sign_time}}</text>
    </view>
  </view>

  <!-- 活动信息 -->
  <view class="event-info" wx:if="{{event}}">
    <text class="event-title">{{event.title}}</text>
    <text class="event-time">🕒 {{event.start_time || event.time || '时间待定'}} - {{event.end_time || '时间待定'}}</text>
    <text class="event-location">📍 {{event.location || '未知地点'}}</text>
  </view>

  <!-- 无活动提示 -->
  <view class="no-event" wx:if="{{!event && !loading}}">
    <text class="no-event-icon">📭</text>
    <text class="no-event-text">活动不存在</text>
  </view>

  <!-- 状态信息 -->
  <view class="status-info" wx:if="{{event}}">
    <view class="status-item">
      <text>报名状态</text>
      <text class="{{userStatus.hasApplied ? 'applied' : ''}}">
        {{userStatus.hasApplied ? '已报名' : '未报名'}}
      </text>
    </view>
    <view class="status-item">
      <text>签到状态</text>
      <text class="{{userStatus.hasSigned ? 'signed' : ''}}">
        {{userStatus.hasSigned ? '已签到' : '未签到'}}
      </text>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tips" wx:if="{{event && !userStatus.hasApplied && !userStatus.hasSigned}}">
    <text class="tips-text">您尚未报名此活动</text>
    <button class="tips-btn" bindtap="goToEventDetail">去报名</button>
  </view>
  
  <view class="tips success-tips" wx:if="{{event && userStatus.hasApplied && userStatus.hasSigned}}">
    <text class="tips-text success">您已完成签到</text>
  </view>
  
  <view class="tips" wx:if="{{event && event.status === 'ended'}}">
    <text class="tips-text warning">活动已结束</text>
  </view>

  <!-- 扫码签到按钮 -->
  <button class="btn btn-primary sign-btn"
          wx:if="{{event && userStatus.hasApplied && !userStatus.hasSigned && event.status !== 'ended'}}"
          bindtap="onScan">
    📷 扫码签到
  </button>
</view>