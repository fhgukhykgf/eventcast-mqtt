.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.scan-area {
  background: white;
  border-radius: 16rpx;
  padding: 60rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.scan-box {
  display: inline-block;
  padding: 40rpx 80rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx dashed #1890ff;
}

.scan-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.no-event {
  text-align: center;
  padding: 80rpx 30rpx;
}

.no-event-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.no-event-text {
  font-size: 32rpx;
  color: #999;
}

.event-info {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.event-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.event-time,
.event-location {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.status-info {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.status-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.status-item:last-child {
  border-bottom: none;
}

.status-item text:last-child.applied {
  color: #52c41a;
}

.status-item text:last-child.signed {
  color: #1890ff;
}

.sign-btn {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  width: auto;
}

.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.success-content {
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 80rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.3);
}

.success-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.success-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #52c41a;
  display: block;
  margin-bottom: 20rpx;
}

.success-time {
  font-size: 28rpx;
  color: #666;
  display: block;
  line-height: 1.5;
}

.tips {
  background: #fff7e6;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tips-text {
  font-size: 28rpx;
  color: #fa8c16;
  flex: 1;
}

.tips-text.warning {
  color: #ff4d4f;
}

.tips-text.success {
  color: #52c41a;
}

.success-tips {
  background: #f6ffed;
}

.tips-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  background: #1890ff;
  color: white;
  border-radius: 20rpx;
  margin-left: 20rpx;
}

.tips-btn::after {
  border: none;
}

.btn {
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: white;
}