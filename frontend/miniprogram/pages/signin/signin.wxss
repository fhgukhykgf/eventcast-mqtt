.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.scan-area {
  background: white;
  border-radius: 16rpx;
  padding: 60rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.scan-box {
  display: inline-block;
  padding: 40rpx 80rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx dashed #1890ff;
}

.scan-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.manual-input {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.input {
  height: 80rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.event-info {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.event-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.event-time,
.event-location {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.status-info {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.status-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.status-item:last-child {
  border-bottom: none;
}

.status-item text:last-child.applied {
  color: #52c41a;
}

.status-item text:last-child.signed {
  color: #1890ff;
}

.sign-btn {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  width: auto;
}

.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.success-content {
  background: white;
  border-radius: 24rpx;
  padding: 60rpx;
  text-align: center;
}

.success-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 30rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #52c41a;
  display: block;
  margin-bottom: 20rpx;
}

.success-time {
  font-size: 28rpx;
  color: #666;
}