# ============ 数据库配置 ============
# 本地MongoDB
MONGODB_URI=mongodb://localhost:27017/eventcast

# 云MongoDB（如MongoDB Atlas）
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eventcast

# ============ MQTT配置 ============
# EMQ X服务器地址
MQTT_BROKER=localhost
MQTT_PORT=1883
# 如需TLS加密，使用8883端口
# MQTT_PORT=8883

# EMQ X管理账号
MQTT_USERNAME=admin
MQTT_PASSWORD=public

# ============ 后端服务配置 ============
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
DEBUG=true  # 开发环境设为true，生产环境设为false

# ============ 文件路径配置 ============
# 日志目录
LOG_DIR=./logs
# 静态文件目录
STATIC_DIR=./static