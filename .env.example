# ============ 数据库配置 ============
# 本地MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/eventcast

# 云MongoDB（如MongoDB Atlas）
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eventcast

# MongoDB连接池配置
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=1
MONGO_MAX_IDLE_TIME_MS=30000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# ============ MQTT配置 ============
# EMQ X服务器地址
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
# 如需TLS加密，使用8883端口
# MQTT_PORT=8883

# EMQ X管理账号
MQTT_USERNAME=admin
MQTT_PASSWORD=public

# MQTT重连配置
MQTT_RECONNECT_DELAY=5
MQTT_MAX_RECONNECT_ATTEMPTS=10

# ============ 后端服务配置 ============
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false

# JWT配置
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ============ CORS配置 ============
# 允许的跨域来源，多个用逗号分隔
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============ 文件路径配置 ============
# 日志目录
LOG_DIR=./logs
LOG_LEVEL=INFO
# 静态文件目录
STATIC_DIR=./static